    "postcss-import": "^16.1.1",
    "posthog-js": "^1.376.6",
    "prismjs": "^1.30.0",
    "prompt-sync": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-image-lightbox": "^5.1.4",
    "react-tabs": "^6.1.1",
    "react-test-renderer": "18.3.1",
    "redent": "^3.0.0",
    "replace-in-path": "^1.1.0",
    "rimraf": "^6.1.3",
    "semver": "^7.8.1",
    "simple-functional-loader": "^1.2.1",
    "tailwindcss": "^3.4.19",
    "tinytime": "^0.2.6",
    "titlecase": "^1.1.3",
    "walk": "^2.3.15"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/react-test-renderer": "18.3.1",
    "@types/semver": "^7.7.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "execa": "^5.1.1",
    "inquirer": "^8.2.7",
    "jest": "^30.4.2",
    "ncp": "^2.0.0",
    "oxlint": "^1.66.0",
    "portless": "^0.13.0",
    "ts-jest": "^29.4.11",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.15.0",
  "resolutions": {
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7"
  }
}
