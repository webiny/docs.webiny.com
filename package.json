{
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "./generator"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:portless": "portless docs yarn dev",
    "generate": "node generateDocs.js",
    "build": "yarn generate && node scripts/generate-v5-redirects.js && next build",
    "build:next": "next build",
    "dev:next": "next dev",
    "start": "next start",
    "export": "yarn build && next export",
    "format": "oxfmt",
    "format:fix": "oxfmt",
    "format:check": "oxfmt --check",
    "eslint": "eslint \"**/*.{js,jsx,ts,tsx}\" --max-warnings=0 --fix",
    "prepare-release-notes": "node scripts/prepareReleaseNotes.js",
    "lint:fix": "yarn format && yarn eslint",
    "get-id": "node -e 'console.log(require(\"@webiny/utils\").mdbid().slice(-8))'",
    "validate:mdx": "tsx scripts/validate-mdx-pairing.ts",
    "generate-sdk-reference": "tsx scripts/generate-sdk-reference.ts",
    "generate:reference": "tsx scripts/generate-reference.ts",
    "generate:changelog": "tsx scripts/generate-changelog.ts",
    "generate:upgrade-guide": "tsx scripts/generate-upgrade-guide.ts",
    "generate:announcements": "tsx scripts/generate-announcements.ts"
  },
  "browserslist": {
    "development": [
      "last 2 chrome versions",
      "last 2 firefox versions",
      "last 2 edge versions"
    ],
    "production": [
      ">1%",
      "not op_mini all",
      "ie 11"
    ]
  },
