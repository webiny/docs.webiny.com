{
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "./generator"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:portless": "portless docs yarn dev",
    "generate": "node generateDocs.js",
    "build": "yarn generate && node scripts/generate-v5-redirects.js && next build",
    "build:next": "next build",
    "dev:next": "next dev",
    "start": "next start",
    "export": "yarn build && next export",
    "format": "oxfmt",
    "format:fix": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "yarn workspaces foreach -A run test",
    "typecheck": "tsc --noEmit --project scripts/tsconfig.json && tsc --noEmit --skipLibCheck --project generator/tsconfig.json && tsc --noEmit --project docs/tsconfig.json",
    "prepare-release-notes": "node scripts/prepareReleaseNotes.js",
    "get-id": "node -e 'console.log(require(\"@webiny/utils\").mdbid().slice(-8))'",
    "validate:mdx": "tsx scripts/validate-mdx-pairing.ts",
    "check:changelog-review": "tsx scripts/check-changelog-review.ts",
    "generate-sdk-reference": "tsx scripts/generate-sdk-reference.ts",
    "generate:reference": "tsx scripts/generate-reference.ts",
    "generate:changelog": "tsx scripts/generate-changelog.ts",
    "generate:upgrade-guide": "tsx scripts/generate-upgrade-guide.ts",
    "generate:announcements": "tsx scripts/generate-announcements.ts"
  },
  "browserslist": {
    "development": [
      "last 2 chrome versions",
      "last 2 firefox versions",
      "last 2 edge versions"
    ],
    "production": [
      ">1%",
      "not op_mini all",
      "ie 11"
    ]
  },
  "dependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@badrap/bar-of-progress": "^0.3.0",
    "@docsearch/react": "^4.6.3",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@juggle/resize-observer": "^3.4.0",
    "@mdx-js/mdx": "^1.6.22",
    "@mdx-js/react": "^1.6.22",
    "@next/bundle-analyzer": "^16.2.6",
    "@reach/alert": "^0.18.0",
    "@reach/rect": "^0.18.0",
    "@silvenon/remark-smartypants": "^2.0.0",
    "@sindresorhus/slugify": "^1.1.2",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/typography": "0.5.19",
    "@webiny/react-composition": "^6.3.0",
    "@webiny/react-properties": "^6.3.0",
    "@webiny/utils": "^6.3.0",
    "@webiny/wts-client": "3.1.4",
    "autoprefixer": "^10.5.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "brotli-size": "^4.0.0",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "classnames": "^2.5.1",
    "clean-css": "^5.3.3",
    "clsx": "^2.1.1",
    "debounce": "2.2.0",
    "dlv": "^1.1.3",
    "file-loader": "^6.2.0",
    "focus-visible": "^5.2.1",
    "front-matter": "^4.0.2",
    "fs-extra": "^11.3.5",
    "globby": "^11.1.0",
    "lodash.memoize": "^4.1.2",
    "minimatch": "^10.2.5",
    "next": "^15.5.18",
    "oxfmt": "^0.51.0",
    "p-map": "4.0.0",
    "p-retry": "^4.6.2",
    "postcss": "^8.5.15",
